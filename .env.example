# Kalshi API key (free tier, read-only)
# Server-side only — used by Vercel Edge Functions
KALSHI_API_KEY=

# football-data.org API key (free tier, covers World Cup)
# Get yours at https://www.football-data.org/client/register
# Optional — ESPN hidden API is used as fallback (no key needed)
FOOTBALL_DATA_API_KEY=

# Client-side polling interval in ms (default: 300000 = 5 minutes)
VITE_ODDS_POLL_INTERVAL=300000
